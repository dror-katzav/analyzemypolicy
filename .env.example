# ── AI Chat — server-side keys (Vercel dashboard, never bundled into browser JS)
# Preferred for production: set these in Vercel → Project Settings → Environment Variables
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── AI Chat — local dev fallback (VITE_ prefix = bundled into browser JS)
# Used only when running outside Vercel (npm run dev).
# Do NOT commit real key values — use server-side keys above for production.
VITE_OPENAI_API_KEY=your-openai-api-key-here
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Atidot Nexus ─────────────────────────────────────────────────────────────
# Flask API URL (defaults to http://localhost:8080 if not set)
VITE_NEXUS_API_URL=http://localhost:8080
# Client identifier passed to /predict/<client>
VITE_NEXUS_CLIENT=AMP_DEMO

# ── Auth ─────────────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
